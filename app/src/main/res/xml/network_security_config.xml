<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
    <!-- Allow cleartext for specific video CDN domains if needed -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="true">api.socialdownloader.app</domain>
    </domain-config>
</network-security-config>
